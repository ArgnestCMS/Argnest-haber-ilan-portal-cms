APP_NAME="Argnest Haber-İlan Portal CMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

PORTAL_NAME="Argnest Haber-İlan Portal CMS"
PORTAL_VERSION=v1.0.0
PORTAL_CODENAME=Genesis
PORTAL_AUTHOR=Argnest
PORTAL_WEBSITE=https://argnest.com
PORTAL_SUPPORT_EMAIL=support@argnest.com
PORTAL_TAGLINE="Modern Haber, İlan ve Topluluk Yönetim Sistemi"

# Production readiness checklist:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://example.com
# LOG_CHANNEL=daily
# LOG_STACK=daily
# LOG_LEVEL=info
# LOG_DAILY_DAYS=14
# CACHE_STORE=database
# QUEUE_CONNECTION=database
# Run before deploy: php artisan storage:link
# Run after deploy: php artisan config:cache && php artisan route:cache && php artisan view:cache
# Queue worker example is listed below. Reverb production command is listed near REVERB_* settings.
# Security headers are enabled in web middleware. CSP starts as Report-Only; review browser reports before enforcing.
# Apache public upload execution guard: storage/app/public/.htaccess. Add equivalent Nginx deny rules in production if needed.
# Health checks: /up for liveness, /health for DB/queue/storage/disk readiness.
# Scheduler example: * * * * * cd /path/to/app && php artisan schedule:run >> /dev/null 2>&1

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=argnest_portal
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
REALTIME_BROADCAST_QUEUE=broadcasts
REALTIME_EVENTS_QUEUE=realtime
REALTIME_NOTIFICATIONS_QUEUE=notifications
MEDIA_QUEUE=media
SAFETY_QUEUE=safety
# Production/database worker example:
# php artisan queue:work database --queue=broadcasts,realtime,notifications,media,safety,default --tries=3 --backoff=5 --timeout=60
#
# Local Redis queue example without Horizon:
# Keep QUEUE_CONNECTION=database unless a local Redis server is running.
# QUEUE_CONNECTION=redis
# REDIS_CLIENT=predis
# REDIS_QUEUE=default
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE_RETRY_AFTER=90
# REDIS_QUEUE_BLOCK_FOR=5
# php artisan queue:work redis --queue=broadcasts,realtime,notifications,media,safety,default --tries=3 --backoff=5 --timeout=60
#
# Production Redis worker example without Horizon:
# Use process manager / Supervisor / systemd to keep this command alive.
# php artisan queue:work redis --queue=broadcasts,realtime,notifications,media,safety,default --tries=3 --backoff=5 --timeout=60 --sleep=1

CACHE_STORE=database
# CACHE_PREFIX=
PORTAL_CACHE_STORE=auto
PORTAL_CACHE_HOME_SECONDS=600
PORTAL_CACHE_LIST_SECONDS=300
PORTAL_CACHE_POPULAR_SECONDS=600
PORTAL_CACHE_TRENDING_SECONDS=600
PORTAL_CACHE_LATEST_SECONDS=300
PORTAL_CACHE_CATEGORY_SECONDS=900
PORTAL_CACHE_SIDEBAR_SECONDS=600
PORTAL_CACHE_AD_SECONDS=300
PORTAL_CACHE_EXTERNAL_SECONDS=600
PORTAL_CACHE_LAYOUT_SECONDS=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_BLOCK_FOR=null

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
# Production Reverb example:
# BROADCAST_CONNECTION=reverb
# REVERB_HOST=ws.example.com
# REVERB_SCHEME=https
# php artisan reverb:start --host=0.0.0.0 --port=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MYSQLDUMP_PATH=

SEO_DEFAULT_ROBOTS=index,follow
SEO_SITEMAP_CACHE_MINUTES=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
